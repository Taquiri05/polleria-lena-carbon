# Clave secreta para firmar sesiones y JWT (generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia_esta_clave_en_produccion
JWT_SECRET_KEY=cambia_esta_clave_jwt_en_produccion

# Entorno Flask: development | testing | production
FLASK_ENV=development

# Base de datos MySQL — desarrollo local
DATABASE_URL_DEV=mysql+pymysql://root:root@localhost:3306/polleria_dev

# Base de datos MySQL — producción (Render / Railway)
DATABASE_URL=mysql+pymysql://user:password@host:3306/polleria_db

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://polleria-frontend.vercel.app

# Puerto del servidor (opcional, por defecto 5000)
PORT=5000
